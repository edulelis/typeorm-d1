{
  "name": "typeorm-d1",
  "version": "1.0.0",
  "description": "TypeORM DataSource adapter for Cloudflare D1",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "ISSUES.md",
    "AGENTS.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "verify:package": "npm run build && node scripts/verify-package.cjs",
    "verify": "npm run build && npm test && npm run verify:package"
  },
  "keywords": [
    "typeorm",
    "cloudflare",
    "d1",
    "sqlite",
    "orm",
    "driver"
  ],
  "author": "typeorm-d1 contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edulelis/typeorm-d1.git"
  },
  "bugs": {
    "url": "https://github.com/edulelis/typeorm-d1/issues"
  },
  "homepage": "https://github.com/edulelis/typeorm-d1#readme",
  "peerDependencies": {
    "reflect-metadata": "^0.1.14 || ^0.2.0",
    "typeorm": "^0.3.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260525.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.41",
    "cross-env": "^10.1.0",
    "jest": "^30.4.2",
    "miniflare": "^4.20260521.0",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.11",
    "tsup": "^8.5.1",
    "typeorm": "^0.3.30",
    "typescript": "^5.9.3"
  }
}
